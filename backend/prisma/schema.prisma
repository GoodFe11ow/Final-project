// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  name         String
  passwordHash String

  tasks         Task[]
  focusSessions FocusSession[]
  settings UserSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  assignatedDate DateTime?
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subtasks Subtasks[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subtasks {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FocusSession {
  id                String   @id @default(cuid())
  mode              String
  completionType    String
  plannedDurationMs Int
  actualElapsedMs   Int
  task              String
  startedAt         DateTime
  endedAt           DateTime
  createdAt         DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  themeMode String @default("light")

  focusDurationSeconds Int @default(2100)
  breakDurationSeconds Int @default(300)

  focusRemindersEnabled  Boolean @default(true)
  focusRemindersTime      String  @default("09:00")
  focusRemindersEveryDay Boolean @default(false)
  focusRemindersWeekdays Boolean @default(true)

  dailySummaryEnabled Boolean @default(true)
  dailySummaryTime    String  @default("20:00")

  timezone String @default("Europe/Tallinn")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
